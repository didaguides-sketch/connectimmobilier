// Transiko Immobilier — schéma de données principal
// Fournisseur : PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ListingType {
  VENTE
  LOCATION
}

enum PropertyType {
  VILLA
  APPARTEMENT
  MAISON
  TERRAIN
  LOCAL_COMMERCIAL
  BUREAU
  FERME
}

enum PropertyStatus {
  BROUILLON
  PUBLIE
  VENDU
  LOUE
  ARCHIVE
}

enum UserRole {
  ADMIN
  EDITOR
  AGENT
}

enum MessageStatus {
  NOUVEAU
  TRAITE
  ARCHIVE
}

model Wilaya {
  id        String     @id @default(cuid())
  code      String     @unique // ex: "16"
  nameAr    String
  nameFr    String
  nameEn    String
  communes  Commune[]
  properties Property[]
}

model Commune {
  id        String   @id @default(cuid())
  nameAr    String
  nameFr    String
  nameEn    String
  wilaya    Wilaya   @relation(fields: [wilayaId], references: [id])
  wilayaId  String
  properties Property[]
}

model Agent {
  id          String     @id @default(cuid())
  fullName    String
  role        String?
  phone       String
  whatsapp    String?
  email       String?   @unique
  photoUrl    String?
  bio         String?
  languages   String[]   @default([])
  active      Boolean    @default(true)
  properties  Property[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Property {
  id              String         @id @default(cuid())
  reference       String         @unique
  titleAr         String
  titleFr         String
  titleEn         String
  slug            String         @unique
  descriptionAr   String?
  descriptionFr   String?
  descriptionEn   String?
  listingType     ListingType
  propertyType    PropertyType
  status          PropertyStatus @default(BROUILLON)
  price           Decimal        @db.Decimal(14, 2)
  currency        String         @default("DZD")
  surface         Float
  rooms           Int?
  bedrooms        Int?
  bathrooms       Int?
  floor           Int?
  featured        Boolean        @default(false)
  latitude        Float?
  longitude       Float?
  address         String?
  amenities       String[]       @default([])
  videoUrl        String?
  wilaya          Wilaya?        @relation(fields: [wilayaId], references: [id])
  wilayaId        String?
  commune         Commune?       @relation(fields: [communeId], references: [id])
  communeId       String?
  agent           Agent?         @relation(fields: [agentId], references: [id])
  agentId         String?
  project         Project?       @relation(fields: [projectId], references: [id])
  projectId       String?
  images          PropertyImage[]
  visitRequests   VisitRequest[]
  aiDescription   String?        // généré par IA si activée
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([listingType, propertyType, status])
  @@index([wilayaId])
}

model PropertyImage {
  id          String   @id @default(cuid())
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId  String
  url         String
  position    Int      @default(0)
  isCover     Boolean  @default(false)
}

model Project {
  id            String     @id @default(cuid())
  nameAr        String
  nameFr        String
  nameEn        String
  slug          String     @unique
  descriptionFr String?
  coverUrl      String?
  wilayaId      String?
  deliveryDate  DateTime?
  properties    Property[]
  createdAt     DateTime   @default(now())
}

model BlogCategory {
  id        String    @id @default(cuid())
  nameFr    String
  slug      String    @unique
  articles  Article[]
  createdAt DateTime  @default(now())
}

model Article {
  id            String   @id @default(cuid())
  titleAr       String
  titleFr       String
  titleEn       String
  slug          String   @unique
  excerptFr     String?
  contentFr     String
  coverUrl      String?
  category      BlogCategory? @relation(fields: [categoryId], references: [id])
  categoryId    String?
  tags          String[] @default([])
  seoTitle      String?
  seoDescription String?
  published     Boolean  @default(false)
  publishedAt   DateTime?
  authorId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Testimonial {
  id         String   @id @default(cuid())
  authorName String
  authorRole String?
  content    String
  rating     Int      @default(5)
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Lead {
  id        String        @id @default(cuid())
  name      String
  phone     String
  email     String?
  message   String?
  source    String        @default("contact") // contact | visite | estimation | chat
  propertyId String?
  status    MessageStatus @default(NOUVEAU)
  createdAt DateTime      @default(now())
}

model VisitRequest {
  id          String   @id @default(cuid())
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId  String
  name        String
  phone       String
  preferredDate DateTime?
  message     String?
  status      MessageStatus @default(NOUVEAU)
  createdAt   DateTime @default(now())
}

model ValuationRequest {
  id           String   @id @default(cuid())
  name         String
  phone        String
  email        String?
  propertyType PropertyType
  wilayaId     String?
  surface      Float?
  rooms        Int?
  notes        String?
  aiEstimate   Decimal? @db.Decimal(14, 2)
  status       MessageStatus @default(NOUVEAU)
  createdAt    DateTime @default(now())
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         UserRole  @default(AGENT)
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  questionFr String
  answerFr   String
  category   String  @default("Général")
  order      Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum MediaType {
  IMAGE
  VIDEO
}

model MediaAsset {
  id        String    @id @default(cuid())
  url       String
  filename  String
  type      MediaType
  sizeBytes Int?
  altText   String?
  folder    String    @default("general") // ex: properties, projects, blog, agents
  createdAt DateTime  @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  userName   String
  action     String   // ex: "create", "update", "delete", "login"
  entityType String   // ex: "Property", "Article", "Agent"
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
