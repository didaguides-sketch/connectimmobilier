# Base de données (Supabase / PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/transiko?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/transiko?schema=public"

# Supabase (stockage des images/vidéos, auth admin)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="xxxxx"
SUPABASE_SERVICE_ROLE_KEY="xxxxx"

# Authentification de l'espace d'administration (NextAuth.js)
# Générez un secret avec : openssl rand -base64 32
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# Intelligence artificielle — optionnel.
# Le site fonctionne normalement tant que ces clés ne sont pas renseignées.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

